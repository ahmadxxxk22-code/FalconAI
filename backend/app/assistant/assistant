    # =====================================================
    # MARKET DETECTION
    # =====================================================

    def detect_market(
        self,
        text: str
    ) -> str:


        message = text.lower()


        crypto_words = [
            "btc",
            "bitcoin",
            "crypto",
            "eth",
            "ethereum",
            "usdt",
            "عملة",
            "عملات"
        ]


        forex_words = [
            "forex",
            "eurusd",
            "gbp",
            "usd",
            "دولار",
            "فوركس"
        ]


        gold_words = [
            "gold",
            "xau",
            "ذهب"
        ]


        stock_words = [
            "stock",
            "shares",
            "nasdaq",
            "sp500",
            "سهم",
            "أسهم"
        ]



        if any(word in message for word in crypto_words):

            return "crypto"


        if any(word in message for word in forex_words):

            return "forex"


        if any(word in message for word in gold_words):

            return "gold"


        if any(word in message for word in stock_words):

            return "stocks"


        return "unknown"



    # =====================================================
    # SIGNAL EXPLANATION ENGINE
    # =====================================================

    def explain_signal(
        self,
        signal: Dict[str, Any],
        language: str = "ar"
    ) -> str:


        if not signal:


            return (

                "لا توجد بيانات إشارة."
                if language == "ar"
                else
                "No signal data available."

            )



        direction = signal.get(
            "signal",
            "WAIT"
        )


        confidence = signal.get(
            "confidence",
            0
        )


        quality = signal.get(
            "quality",
            "D"
        )


        reasons = signal.get(
            "reasons",
            []
        )



        if language == "ar":


            text = (

                f"إشارة FalconAI: {direction}\n"

                f"الثقة: {confidence}%\n"

                f"الجودة: {quality}\n\n"

                "الأسباب:\n"

            )


        else:


            text = (

                f"FalconAI Signal: {direction}\n"

                f"Confidence: {confidence}%\n"

                f"Quality: {quality}\n\n"

                "Reasons:\n"

            )



        for reason in reasons:

            text += f"- {reason}\n"



        return text



