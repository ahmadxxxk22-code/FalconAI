    # =====================================================
    # LANGUAGE DETECTION
    # =====================================================

    def detect_language(
        self,
        text: str
    ) -> str:

        arabic = 0
        english = 0


        for char in text:

            if "\u0600" <= char <= "\u06FF":

                arabic += 1

            elif char.isalpha():

                english += 1


        if arabic > english:

            return "ar"


        return "en"



    # =====================================================
    # CLEAN MESSAGE
    # =====================================================

    def clean_message(
        self,
        message: str
    ) -> str:


        if not message:

            return ""


        return " ".join(
            message.strip().split()
        )



    # =====================================================
    # MEMORY
    # =====================================================

    def save_memory(
        self,
        user_id: str,
        role: str,
        content: str
    ):


        if user_id not in self.memory:

            self.memory[user_id] = []


        self.memory[user_id].append({

            "role": role,

            "content": content,

            "time": datetime.utcnow().isoformat()

        })


        if len(self.memory[user_id]) > self.max_memory_messages:

            self.memory[user_id] = (
                self.memory[user_id]
                [-self.max_memory_messages:]
            )



    def get_memory(
        self,
        user_id: str
    ) -> List[Dict[str, Any]]:


        return self.memory.get(
            user_id,
            []
        )



    # =====================================================
    # MARKET DETECTION
    # =====================================================

    def detect_market(
        self,
        message: str
    ) -> str:


        text = message.lower()


        for market, words in self.supported_markets.items():

            for word in words:

                if word in text:

                    return market


        return "unknown"



    # =====================================================
    # MAIN CHAT
    # =====================================================

    def chat(
        self,
        message: str,
        user_id: Optional[str] = None,
        language: Optional[str] = None,
        context: Optional[Dict[str, Any]] = None
    ) -> Dict[str, Any]:


        message = self.clean_message(
            message
        )


        if not language:

            language = self.detect_language(
                message
            )


        market = self.detect_market(
            message
        )


        if user_id:

            self.save_memory(
                user_id,
                "user",
                message
            )


        response = self.generate_response(

            message,

            language,

            market,

            context

        )


        if user_id:

            self.save_memory(

                user_id,

                "assistant",

                response

            )


        return {

            "response": response,

            "language": language,

            "market": market,

            "timestamp": datetime.utcnow().isoformat()

        }



